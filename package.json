{
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "pnpm lint:biome && pnpm lint:eslint",
    "lint:biome": "biome check .",
    "lint:eslint": "eslint .",
    "lint:fix": "biome check --write . && eslint . --fix",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest --run --coverage",
    "knip": "knip",
    "db:lint": "find supabase/migrations -name '*.sql' -print0 2>/dev/null | xargs -0 -I{} pglast --parse '{}' || true"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.1",
    "@radix-ui/react-dropdown-menu": "^2.1.14",
    "@radix-ui/react-label": "^2.1.6",
    "@radix-ui/react-slot": "^1.2.2",
    "@supabase/ssr": "latest",
    "@supabase/supabase-js": "latest",
    "@t3-oss/env-nextjs": "^0.13.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.511.0",
    "next": "latest",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.3.0",
    "zod": "^4.4.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lefthook",
      "sharp",
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@eslint/js": "^9",
    "@next/eslint-plugin-next": "latest",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/eslint-plugin": "^1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9",
    "eslint-plugin-drizzle": "^0.2",
    "eslint-plugin-erasable-syntax-only": "latest",
    "eslint-plugin-functional": "^9",
    "eslint-plugin-import-x": "^4",
    "eslint-plugin-jsx-a11y": "^6",
    "eslint-plugin-n": "^17",
    "eslint-plugin-no-secrets": "^1",
    "eslint-plugin-perfectionist": "^4",
    "eslint-plugin-playwright": "^2",
    "eslint-plugin-promise": "^7",
    "eslint-plugin-react": "^7",
    "eslint-plugin-react-hooks": "latest",
    "eslint-plugin-regexp": "^2",
    "eslint-plugin-security": "^3",
    "eslint-plugin-sonarjs": "^3",
    "eslint-plugin-unicorn": "^57",
    "globals": "^16",
    "jiti": "^2",
    "jsdom": "^25.0.1",
    "knip": "^5",
    "lefthook": "^1",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "turbo": "^2",
    "typescript": "^5",
    "typescript-eslint": "^8",
    "vitest": "^3.2.4"
  }
}
