# Canonical site URL — required. Production: https://ituri-epi.com. Local: http://localhost:3000.
NEXT_PUBLIC_SITE_URL=

# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Postgres — use `vercel env pull` to populate from the Vercel-Supabase integration
POSTGRES_URL_NON_POOLING=

# LLM + background jobs
ANTHROPIC_API_KEY=
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
# REST API key for querying run history — separate from signing key; issue from Inngest dashboard > Settings > API keys
INNGEST_API_KEY=

# Ingest adapter credentials (optional — adapters throw visibly when missing at runtime)
# ReliefWeb: register an app name at https://reliefweb.int/help/api
RELIEFWEB_APPNAME=
# ACLED: request access at https://acleddata.com/acleddatanew/wp-content/uploads/dlm_uploads/2023/06/ACLED_Terms-of-Use.pdf
ACLED_ACCESS_TOKEN=
ACLED_EMAIL=

# Phase 7 — cost kill-switch (Edge Config connection string from Vercel dashboard)
EDGE_CONFIG=

# Phase 7 — Slack notifications (incoming webhook URL, optional)
SLACK_WEBHOOK_URL=

# Phase 7 — Twilio SMS escalations (all four required for SMS delivery, optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TO_NUMBER=

# Phase 7 — GitHub issue escalations (both required, optional)
GITHUB_TOKEN=
GITHUB_REPO=

# Phase 7 — Upstash Redis rate limiting in proxy.ts (optional; graceful no-op when unset)
# Provision at https://console.upstash.com — create a Redis database, copy REST URL + token.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Phase 7 — Langfuse / OTel observability (optional)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=
SENTRY_DSN=
