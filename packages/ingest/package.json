{
  "name": "@ituri/ingest",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "backfill": "tsx src/bin/backfill.ts",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mozilla/readability": "^0.5.0",
    "jsdom": "^25.0.1",
    "robots-parser": "^3.0.1",
    "rss-parser": "^3.13.0",
    "unpdf": "^1.6.2"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "@types/node": "^20",
    "tsx": "^4.22.3",
    "vitest": "^3.2.4"
  }
}
